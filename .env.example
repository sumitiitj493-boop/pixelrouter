# Copy this file to .env and fill in your values
# NEVER commit .env to git

GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp-key.json
GCS_BUCKET_NAME=pixelrouter-images
GCS_OBJECT_PREFIX=jobs
GCS_URL_STRATEGY=gcs_uri
GCS_SIGNED_URL_TTL_SECONDS=3600
REDIS_URL=redis://redis:6379
LOAD_BALANCER_URL=http://load-balancer:8001
PROCESSOR_URLS=http://processor-1:8002,http://processor-2:8003
MAX_CPU_THRESHOLD=80
METRICS_REFRESH_TIMEOUT_SECONDS=2
LOCAL_AUTOSCALE_ENABLED=true
MAX_PROCESSORS=5
PROCESSOR_BASE_PORT=8002
PROCESSOR_IMAGE=pixelrouter-processor:latest
PROCESSOR_NETWORK=pixelrouter_pixelrouter-network
CLOUD_RUN_PROCESSOR_URL=
LOG_LEVEL=INFO
